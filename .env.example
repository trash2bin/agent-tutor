# =============================================================================
# Agent-Tutor — переменные окружения
# =============================================================================
# Скопируй в .env и заполни:
#   cp .env.example .env
#
# Запуск:
#   docker compose up -d                           # 4 long-running сервиса
#   docker compose --profile prod up -d            # + Caddy (HTTPS)
#   docker compose --profile tools run --rm agent agent-ingest list
#   docker compose --profile cron up -d            # + backup-сервис
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# База данных (оставь пустым для SQLite, укажи для PostgreSQL)
# Для локального PostgreSQL: docker compose up db
# DATABASE_URL=postgresql://tutor:tutor@127.0.0.1:5432/agent_tutor
# Для Docker Compose (все сервисы внутри сети):
# DATABASE_URL=postgresql://tutor:tutor@db:5432/agent_tutor
DATABASE_URL=

# LLM-провайдер (ОБЯЗАТЕЛЬНО: хотя бы один)
# ─────────────────────────────────────────────────────────────────────────────

# Ollama (локальный или удалённый)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:0.5b

# Mistral API (альтернатива Ollama, оставить пустым если не используется)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral/mistral-small

# ─────────────────────────────────────────────────────────────────────────────
# RAG-сервис
# ─────────────────────────────────────────────────────────────────────────────

# Embedding-модель (HF-id или локальный путь)
RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# Устройство: cpu, cuda, mps
RAG_DEVICE=cpu
# Тип чанкера: semantic, recursive, sentence
RAG_CHUNKER_TYPE=semantic
# Только локальные файлы (не скачивать модель каждый раз)
RAG_LOCAL_FILES_ONLY=0

# ─────────────────────────────────────────────────────────────────────────────
# Агент (API)
# ─────────────────────────────────────────────────────────────────────────────

# Режим мышления (true=вкл, false=выкл). В prod рекомендуется false.
ENABLE_THINK=true
# Таймаут на полный turn агента (сек). В prod ~90, в dev ~600.
DEMO_REQUEST_TIMEOUT=600
# Сколько ходов истории хранить
DEMO_HISTORY_TURNS=8
# Максимальная длина контента в истории (символов)
DEMO_HISTORY_CONTENT_CHARS=6000
# Температура модели
AGENT_TEMPERATURE=0.5
# Максимум итераций агента (tool calls за один turn)
AGENT_MAX_ITERATIONS=5
# Максимум токенов для reasoning (thinking mode)
AGENT_MAX_TOKENS_THINKING=4096
# Максимум пустых раундов (thinking без ответа)
AGENT_MAX_EMPTY_ROUNDS=3
# Дней хранить backlog-файлы
BACKLOG_RETENTION_DAYS=30

# ─────────────────────────────────────────────────────────────────────────────
# Безопасность
# ─────────────────────────────────────────────────────────────────────────────

# Bearer-токен для API (обязателен в prod, опционален в dev)
API_BEARER_TOKEN=
# CORS-origin для web-сервиса (в prod — явный домен, не *)
WEB_ORIGIN=*

# ─────────────────────────────────────────────────────────────────────────────
# Домен для Caddy (только в prod-профиле)
# ─────────────────────────────────────────────────────────────────────────────

DOMAIN=localhost

# ─────────────────────────────────────────────────────────────────────────────
# Генерация материалов (agent-generate)
# ─────────────────────────────────────────────────────────────────────────────

# Ollama-модель для генерации
DOCGEN_MODEL=qwen2.5:0.5b
# Endpoint /api/generate
DOCGEN_OLLAMA_URL=http://host.docker.internal:11434/api/generate
# Папка для сгенерированных материалов
DOCGEN_OUTPUT_DIR=/data/app/generated_materials

# ─────────────────────────────────────────────────────────────────────────────
# Бэкапы
# ─────────────────────────────────────────────────────────────────────────────

# Дней хранить бэкапы
BACKUP_RETENTION_DAYS=14
# Часов между бэкапами
BACKUP_INTERVAL_HOURS=6
